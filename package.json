{
  "version": "1.1",
  "scripts": {
    "start:dev": "bun run --watch",
    "tests": "bun run lint",
    "build": "bun run build:windows-x64 && bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:linux-x64-musl && bun run build:linux-arm64-musl && bun run build:darwin-arm64 && bun run build:darwin-x64",
    "build:windows-x64": "bun build --compile --minify --target bun-windows-x64 --outfile ./builds/stress-v1.1--windows-x64 ./src/main.ts",
    "build:linux-x64": "bun build --compile --minify --target bun-linux-x64 --outfile ./builds/stress-v1.1--linux-x64 ./src/main.ts",
    "build:linux-arm64": "bun build --compile --minify --target bun-linux-arm64 --outfile ./builds/stress-v1.1--linux-arm64 ./src/main.ts",
    "build:linux-x64-musl": "bun build --compile --minify --target bun-linux-x64-musl --outfile ./builds/stress-v1.1--linux-x64-musl ./src/main.ts",
    "build:linux-arm64-musl": "bun build --compile --minify --target bun-linux-arm64-musl --outfile ./builds/stress-v1.1--linux-arm64-musl ./src/main.ts",
    "build:darwin-arm64": "bun build --compile --minify --target bun-darwin-arm64 --outfile ./builds/stress-v1.1--macos-arm64 ./src/main.ts",
    "build:darwin-x64": "bun build --compile --minify --target bun-darwin-x64 --outfile ./builds/stress-v1.1--macos-x64 ./src/main.ts",
    "prettier": "prettier --write ./",
    "lint": "eslint ./"
  },
  "dependencies": {
    "@keift/utils": "^1.0.2",
    "@types/bun": "^1.3.12",
    "@types/random-useragent": "^0.3.3",
    "dayjs": "^1.11.20",
    "prettier": "^3.8.3",
    "random-useragent": "^0.5.0",
    "rulint": "^1.1.4",
    "typof": "^1.0.16"
  }
}
